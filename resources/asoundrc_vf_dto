pcm.playback_hw {
    type hw
    card "Device"
    device 0
    format S32_LE
    channels 2
    rate 48000
}

pcm.capture_hw {
    type hw
    card "Device"
    device 1
    format S32_LE
    channels 2
    rate 48000
}

pcm.VF_Playback {
    type plug
    slave.pcm {
	type softvol
	slave.pcm {
	    type dmix
	    ipc_key 256
	    ipc_perm 0666
	    slave.pcm "playback_hw"
	}
	control {
	    name "Playback Volume"
	    card "Device"
	}
    }
}

pcm.VF_Capture {
    type plug
    slave.pcm {
	type softvol
	slave.pcm {
	    type dsnoop
	    ipc_key 512
	    ipc_perm 0666
	    slave.pcm "capture_hw"
	}
	control {
	    name "Capture Volume"
	    card "Device"
	}
    }
}

pcm.!default {
    type asym
    playback.pcm "VF_Playback"
    capture.pcm "VF_Capture"
}

pcm.playback {
    type plug
    slave.pcm "VF_Playback"
}

pcm.capture {
    type plug
    slave.pcm "VF_Capture"
}
